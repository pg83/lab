{
  "uid": "{{cluster}}",
  "title": "{{cluster}}",
  "tags": ["etcd"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 0,
  "time": {"from": "now-30m", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "refresh": "15s",
  "annotations": {"list": []},
  "templating": {"list": []},
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Leader state per member (1 = has leader)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 1}},
      "targets": [
        {"expr": "etcd_server_has_leader{job=\"{{cluster}}\"}", "legendFormat": "{% raw %}{{host}}{% endraw %}", "refId": "A"}
      ]
    },
    {
      "id": 2,
      "title": "Leader changes seen (total)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"expr": "etcd_server_leader_changes_seen_total{job=\"{{cluster}}\"}", "legendFormat": "{% raw %}{{host}}{% endraw %}", "refId": "A"}
      ]
    },
    {
      "id": 3,
      "title": "Proposals /s (committed / applied / failed)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [
        {"expr": "sum by (host) (rate(etcd_server_proposals_committed_total{job=\"{{cluster}}\"}[1m]))", "legendFormat": "{% raw %}{{host}}{% endraw %} committed", "refId": "A"},
        {"expr": "sum by (host) (rate(etcd_server_proposals_applied_total{job=\"{{cluster}}\"}[1m]))", "legendFormat": "{% raw %}{{host}}{% endraw %} applied", "refId": "B"},
        {"expr": "sum by (host) (rate(etcd_server_proposals_failed_total{job=\"{{cluster}}\"}[1m]))", "legendFormat": "{% raw %}{{host}}{% endraw %} failed", "refId": "C"}
      ]
    },
    {
      "id": 4,
      "title": "Proposals pending (gauge)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [
        {"expr": "etcd_server_proposals_pending{job=\"{{cluster}}\"}", "legendFormat": "{% raw %}{{host}}{% endraw %}", "refId": "A"}
      ]
    },
    {
      "id": 5,
      "title": "WAL fsync duration p99 (per member)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {"expr": "histogram_quantile(0.99, sum by (le, host) (rate(etcd_disk_wal_fsync_duration_seconds_bucket{job=\"{{cluster}}\"}[5m])))", "legendFormat": "{% raw %}{{host}}{% endraw %}", "refId": "A"}
      ]
    },
    {
      "id": 6,
      "title": "Backend commit duration p99 (the 'apply took too long' signal)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {"expr": "histogram_quantile(0.99, sum by (le, host) (rate(etcd_disk_backend_commit_duration_seconds_bucket{job=\"{{cluster}}\"}[5m])))", "legendFormat": "{% raw %}{{host}}{% endraw %}", "refId": "A"}
      ]
    },
    {
      "id": 7,
      "title": "MVCC DB total size",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "targets": [
        {"expr": "etcd_mvcc_db_total_size_in_bytes{job=\"{{cluster}}\"}", "legendFormat": "{% raw %}{{host}}{% endraw %} total", "refId": "A"},
        {"expr": "etcd_mvcc_db_total_size_in_use_in_bytes{job=\"{{cluster}}\"}", "legendFormat": "{% raw %}{{host}}{% endraw %} in-use", "refId": "B"}
      ]
    },
    {
      "id": 8,
      "title": "gRPC incoming traffic (recv/send bytes/s)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "targets": [
        {"expr": "sum by (host) (rate(etcd_network_client_grpc_received_bytes_total{job=\"{{cluster}}\"}[1m]))", "legendFormat": "{% raw %}{{host}}{% endraw %} rx", "refId": "A"},
        {"expr": "sum by (host) (rate(etcd_network_client_grpc_sent_bytes_total{job=\"{{cluster}}\"}[1m]))", "legendFormat": "{% raw %}{{host}}{% endraw %} tx", "refId": "B"}
      ]
    },
    {
      "id": 9,
      "title": "Raft peer round-trip p99",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {"expr": "histogram_quantile(0.99, sum by (le, To) (rate(etcd_network_peer_round_trip_time_seconds_bucket{job=\"{{cluster}}\"}[5m])))", "legendFormat": "to {% raw %}{{To}}{% endraw %}", "refId": "A"}
      ]
    },
    {
      "id": 10,
      "title": "Recent etcd errors/warns (via Loki)",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 30},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "{service=\"{{cluster}}\"} |~ \"\\\"level\\\":\\\"(warn|error|fatal)\\\"\"", "refId": "A"}
      ]
    }
  ]
}
