    {"id": 1, "title": "Load — cluster sum", "type": "timeseries",
     "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
     "datasource": {"type": "prometheus", "uid": "prom"},
     "targets": [
       {"expr": "sum(node_load1)",  "legendFormat": "1m",  "refId": "A"},
       {"expr": "sum(node_load5)",  "legendFormat": "5m",  "refId": "B"},
       {"expr": "sum(node_load15)", "legendFormat": "15m", "refId": "C"}
     ]},
