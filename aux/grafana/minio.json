{
  "uid": "minio",
  "title": "MinIO",
  "tags": ["minio", "s3"],
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "graphTooltip": 0,
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "refresh": "10s",
  "annotations": {"list": []},
  "templating": {"list": []},
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Request rate by host",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [
        {"expr": "sum by (host) (rate(minio_s3_requests_total{job=\"minio\"}[1m]))", "legendFormat": "{{host}}", "refId": "A"}
      ]
    },
    {
      "id": 2,
      "title": "Error rate (4xx / 5xx / total)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [
        {"expr": "sum (rate(minio_s3_requests_4xx_errors_total{job=\"minio\"}[1m]))", "legendFormat": "4xx", "refId": "A"},
        {"expr": "sum (rate(minio_s3_requests_5xx_errors_total{job=\"minio\"}[1m]))", "legendFormat": "5xx", "refId": "B"},
        {"expr": "sum (rate(minio_s3_requests_errors_total{job=\"minio\"}[1m]))", "legendFormat": "total", "refId": "C"}
      ]
    },
    {
      "id": 3,
      "title": "Request TTFB (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(minio_s3_requests_ttfb_seconds_distribution{job=\"minio\"}[1m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(minio_s3_requests_ttfb_seconds_distribution{job=\"minio\"}[1m])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(minio_s3_requests_ttfb_seconds_distribution{job=\"minio\"}[1m])))", "legendFormat": "p99", "refId": "C"}
      ]
    },
    {
      "id": 4,
      "title": "Inflight + waiting",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "targets": [
        {"expr": "sum by (host) (minio_s3_requests_inflight_total{job=\"minio\"})", "legendFormat": "inflight {{host}}", "refId": "A"},
        {"expr": "sum by (host) (minio_s3_requests_waiting_total{job=\"minio\"})", "legendFormat": "waiting {{host}}", "refId": "B"}
      ]
    },
    {
      "id": 5,
      "title": "Bytes received (in)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "targets": [
        {"expr": "sum by (host) (rate(minio_s3_traffic_received_bytes{job=\"minio\"}[1m]))", "legendFormat": "{{host}}", "refId": "A"}
      ]
    },
    {
      "id": 6,
      "title": "Bytes sent (out)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "targets": [
        {"expr": "sum by (host) (rate(minio_s3_traffic_sent_bytes{job=\"minio\"}[1m]))", "legendFormat": "{{host}}", "refId": "A"}
      ]
    },
    {
      "id": 7,
      "title": "Request rejections",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [
        {"expr": "sum (rate(minio_s3_requests_rejected_auth_total{job=\"minio\"}[1m]))", "legendFormat": "auth", "refId": "A"},
        {"expr": "sum (rate(minio_s3_requests_rejected_header_total{job=\"minio\"}[1m]))", "legendFormat": "header", "refId": "B"},
        {"expr": "sum (rate(minio_s3_requests_rejected_invalid_total{job=\"minio\"}[1m]))", "legendFormat": "invalid", "refId": "C"},
        {"expr": "sum (rate(minio_s3_requests_rejected_timestamp_total{job=\"minio\"}[1m]))", "legendFormat": "timestamp", "refId": "D"}
      ]
    },
    {
      "id": 8,
      "title": "Nodes online / offline",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "targets": [
        {"expr": "sum by (host) (minio_cluster_nodes_online_total{job=\"minio\"})", "legendFormat": "online {{host}}", "refId": "A"},
        {"expr": "sum by (host) (minio_cluster_nodes_offline_total{job=\"minio\"})", "legendFormat": "offline {{host}}", "refId": "B"}
      ]
    },
    {
      "id": 9,
      "title": "Recent minio errors (via Loki)",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 24},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "{service=\"minio\"} |~ \"(?i)error|fatal|panic|fail|corrupt|broken pipe|offline\"", "refId": "A"}
      ]
    },
    {
      "id": 10,
      "title": "Inter-node TX per host (sum across remote peers)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 34},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "targets": [
        {"expr": "sum by (host) (rate(minio_inter_node_traffic_sent_bytes{job=\"minio\"}[1m]))", "legendFormat": "{{host}}", "refId": "A"}
      ]
    },
    {
      "id": 11,
      "title": "Inter-node RX per host (sum across remote peers)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 34},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "targets": [
        {"expr": "sum by (host) (rate(minio_inter_node_traffic_received_bytes{job=\"minio\"}[1m]))", "legendFormat": "{{host}}", "refId": "A"}
      ]
    },
    {
      "id": 12,
      "title": "Inter-node TX by peer pair (host → server, includes self-loops)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 40},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "targets": [
        {"expr": "rate(minio_inter_node_traffic_sent_bytes{job=\"minio\"}[1m])", "legendFormat": "{{host}} → {{server}}", "refId": "A"}
      ]
    },
    {
      "id": 13,
      "title": "Inter-node dial errors / s",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 48},
      "datasource": {"type": "prometheus", "uid": "prom"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [
        {"expr": "rate(minio_inter_node_traffic_dial_errors{job=\"minio\"}[1m])", "legendFormat": "{{host}} → {{server}}", "refId": "A"},
        {"expr": "rate(minio_inter_node_traffic_errors_total{job=\"minio\"}[1m])", "legendFormat": "{{host}} errors_total", "refId": "B"}
      ]
    }
  ]
}
